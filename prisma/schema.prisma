// =============================================================================
// Farm Intelligence Platform — Prisma Schema
// =============================================================================
// Database: Supabase Postgres
// Key decisions:
//   - UUID primary keys (Supabase convention, prevents ID enumeration)
//   - Composite unique on FieldCropYear(fieldId, cropId, year) prevents dupes
//   - JSON for quality_metrics (semi-structured, varies by crop type)
//   - Cascade deletes from parent → child where data is dependent
//   - All tables have createdAt/updatedAt for audit trail
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// Auth: Managed by Supabase Auth, extended with role
// =============================================================================
// We do NOT manage auth.users directly — Supabase owns that table.
// This profile table links to Supabase's auth.users via id.
// =============================================================================

enum UserRole {
  ADMIN
  VIEWER
}

model UserProfile {
  id        String   @id @db.Uuid // Matches Supabase auth.users.id
  email     String   @unique
  fullName  String?  @map("full_name")
  role      UserRole @default(VIEWER)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  importLogs ImportLog[]

  @@map("user_profiles")
}

// =============================================================================
// Core Domain Models
// =============================================================================

model Field {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @unique // e.g., "North Quarter", "River Field"
  acreage   Decimal  @db.Decimal(10, 2)
  soilType  String?  @map("soil_type") // e.g., "Clay Loam", "Sandy"
  location  String?  // Free-text or coordinates
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  fieldCropYears FieldCropYear[]

  @@map("fields")
}

model Crop {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @unique // e.g., "Winter Wheat", "Oilseed Rape"
  category  String?  // e.g., "Cereal", "Oilseed", "Pulse"
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  varieties      Variety[]
  fieldCropYears FieldCropYear[]

  @@map("crops")
}

model Variety {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   // e.g., "Skyfall", "Crusoe"
  cropId    String   @map("crop_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  crop           Crop            @relation(fields: [cropId], references: [id], onDelete: Cascade)
  fieldCropYears FieldCropYear[]

  @@unique([cropId, name]) // No duplicate variety names within a crop
  @@map("varieties")
}

// =============================================================================
// FieldCropYear: The central fact table
// =============================================================================
// Each row = one field × one crop × one harvest year.
// This is where yield, cost, and quality data live.
// =============================================================================

model FieldCropYear {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fieldId        String   @map("field_id") @db.Uuid
  cropId         String   @map("crop_id") @db.Uuid
  varietyId      String?  @map("variety_id") @db.Uuid
  year           Int      // Harvest year, e.g. 2024
  yieldPerAcre   Decimal? @map("yield_per_acre") @db.Decimal(10, 2) // tonnes/acre
  totalYield     Decimal? @map("total_yield") @db.Decimal(12, 2) // tonnes
  plantingDate   DateTime? @map("planting_date") @db.Date
  harvestDate    DateTime? @map("harvest_date") @db.Date
  qualityMetrics Json?    @map("quality_metrics") // e.g., { moisture: 14.2, protein: 12.5 }
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relations
  field      Field      @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  crop       Crop       @relation(fields: [cropId], references: [id], onDelete: Cascade)
  variety    Variety?   @relation(fields: [varietyId], references: [id], onDelete: SetNull)
  financials Financial?

  // Business rule: one crop per field per year
  @@unique([fieldId, cropId, year])
  @@index([year])
  @@index([cropId])
  @@map("field_crop_years")
}

// =============================================================================
// Financials: Linked 1:1 with FieldCropYear
// =============================================================================

model Financial {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  fieldCropYearId String   @unique @map("field_crop_year_id") @db.Uuid
  seedCost        Decimal? @map("seed_cost") @db.Decimal(10, 2)
  fertilizerCost  Decimal? @map("fertilizer_cost") @db.Decimal(10, 2)
  sprayCost       Decimal? @map("spray_cost") @db.Decimal(10, 2)
  operationsCost  Decimal? @map("operations_cost") @db.Decimal(10, 2)
  totalCost       Decimal? @map("total_cost") @db.Decimal(12, 2)
  revenuePerTonne Decimal? @map("revenue_per_tonne") @db.Decimal(10, 2)
  totalRevenue    Decimal? @map("total_revenue") @db.Decimal(12, 2)
  grossMargin     Decimal? @map("gross_margin") @db.Decimal(12, 2)
  costPerAcre     Decimal? @map("cost_per_acre") @db.Decimal(10, 2)
  revenuePerAcre  Decimal? @map("revenue_per_acre") @db.Decimal(10, 2)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  fieldCropYear FieldCropYear @relation(fields: [fieldCropYearId], references: [id], onDelete: Cascade)

  @@map("financials")
}

// =============================================================================
// ImportLog: Audit trail for all data imports
// =============================================================================

model ImportLog {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  fileName      String   @map("file_name")
  rowsProcessed Int      @map("rows_processed")
  rowsFailed    Int      @map("rows_failed")
  status        String   // "success" | "partial" | "failed"
  errors        Json?    // Array of { row: number, field: string, message: string }
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("import_logs")
}
